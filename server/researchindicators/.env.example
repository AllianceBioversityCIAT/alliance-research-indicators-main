ARI_MQ_HOST=xxxxx
ARI_MQ_USER=xxxxx
ARI_MQ_PASSWORD=xxxxx
ARI_PORT=xxxxx
ARI_IS_PRODUCTION=xxxxx
ARI_SEE_ALL_LOGS=xxxxx
ARI_JWT_ACCESS_EXPIRES_IN=xxxxx
ARI_MYSQL_HOST=xxxxx
ARI_MYSQL_USER_NAME=xxxxx
ARI_MYSQL_USER_PASS=xxxxx
ARI_MYSQL_NAME=xxxxx

# Optional: comma-separated sheet_key values to override Excel tab order for STAR metadata export (e.g. raw_data,data_dictionary)
ARI_STAR_RESULTS_METADATA_SHEET_ORDER=

# Optional: PNG/JPEG URL for STAR raw-data Excel header logo (defaults to Alliance CDN)
# ARI_STAR_RESULTS_HEADER_LOGO_URL=

# PRMS public-results-framework host — base URL for the ToC integration
# consumed by GET .../pool-funding-alignment/hlos-indicators (T-15.12).
# Same value in dev / staging / prod during the testing wave (2026-05-27).
# When unset, PrmsTocService returns 503 instead of crashing.
ARI_PRMS_TOC_HOST=https://prtest-back.ciat.cgiar.org

# lambda-toc host — base URL for the level-based ToC catalog integration
# consumed by GET .../pool-funding-alignment/hlos-indicators (toc-mapping-v2 T-01).
# No auth headers. When unset, TocIntegrationService returns 503 instead of crashing.
ARI_TOC_INTEGRATION_HOST=https://lambda-toc.clarisa.cgiar.org